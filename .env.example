# Database
# Local example: postgresql://postgres:postgres@localhost:5432/playwright_test
DATABASE_URL=

# Optional Prisma/Vercel aliases (app falls back in this order)
POSTGRES_PRISMA_URL=
PRISMA_DATABASE_URL=

# Auth.js / NextAuth secrets (set at least one; setting both is recommended)
AUTH_SECRET=
NEXTAUTH_SECRET=

# Optional base URL for auth callbacks in some environments
# Local example: http://localhost:3000
AUTH_URL=
