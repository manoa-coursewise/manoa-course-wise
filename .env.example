# -----------------------------------------------------------------------
# TEAM ONBOARDING — How to get credentials for local development
# -----------------------------------------------------------------------
# The shared database lives on db.prisma.io (Vercel-hosted Postgres).
# Do NOT manually fill in these values — use Vercel CLI to pull them:
#
#   npm i -g vercel
#   vercel login
#   vercel link          # run once inside the final-project/ folder
#   vercel env pull .env.local
#   npx prisma generate
#
# This creates a .env.local file (git-ignored) with all the correct
# connection strings pointing to the shared production database.
# -----------------------------------------------------------------------

# Database — filled automatically by `vercel env pull .env.local`
DATABASE_URL=
POSTGRES_URL=
PRISMA_DATABASE_URL=

# Auth.js / NextAuth secrets (set at least one; setting both is recommended)
AUTH_SECRET=
NEXTAUTH_SECRET=

# Optional base URL for auth callbacks in some environments
# Local example: http://localhost:3000
AUTH_URL=
