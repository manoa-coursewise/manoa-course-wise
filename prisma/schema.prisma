generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int      @id @default(autoincrement())
  email    String   @unique
  username String   @unique
  password String
  role     Role     @default(USER)
  reviews  Review[]
}

model Stuff {
  id        Int       @id @default(autoincrement())
  name      String
  quantity  Int
  condition Condition @default(good)
  owner     String
}

model Review {
  id            Int        @id @default(autoincrement())
  rating        Float
  text          String
  anonymous     Boolean    @default(false)
  authorEmail   String?
  tags          String[]   @default([])
  createdAt     DateTime   @default(now())
  semesterTaken String?
  courseId      Int
  professorId   Int?
  userId        Int?
  clarity       Float
  difficulty    Float
  workload      Float
  course        Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  professor     Professor? @relation(fields: [professorId], references: [id])
  user          User?      @relation(fields: [userId], references: [id])

  @@index([courseId])
  @@index([userId])
  @@index([professorId])
}

model Course {
  id         Int         @id @default(autoincrement())
  classId    String      @unique
  name       String
  professors Professor[]
  reviews    Review[]
}

model Professor {
  id       Int      @id @default(autoincrement())
  name     String
  courseId Int
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  reviews  Review[]

  @@unique([courseId, name])
  @@index([name])
}

enum Role {
  USER
  ADMIN
}

enum Condition {
  excellent
  good
  fair
  poor
}
